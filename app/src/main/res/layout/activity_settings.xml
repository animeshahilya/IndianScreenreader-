<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Indian Screenreader"
            android:textColor="?attr/colorPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:contentDescription="Indian Screenreader Settings Menu"
            android:focusable="true" />

        <!-- AI Engine Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI &amp; Smart Features"
                    android:textColor="?attr/colorSecondary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:focusable="true" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Gemini API Key">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etApiKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:minHeight="64dp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:contentDescription="Enter your Google AI Studio Gemini API Key here" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAutoTranslate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Auto-Translate (Hindi)"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:minHeight="64dp"
                    android:contentDescription="Toggle AI Auto Translate to Hindi. Double tap to toggle." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Navigation & TTS Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigation &amp; Speech"
                    android:textColor="?attr/colorSecondary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:focusable="true" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchScreenCurtain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Screen Curtain"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:minHeight="64dp"
                    android:contentDescription="Toggle Screen Curtain. When enabled, the screen turns completely black for privacy while the screen reader remains active. Double tap to toggle." />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchInputHelp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Input Help Mode (Practice)"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:minHeight="64dp"
                    android:contentDescription="Toggle Input Help Mode. When enabled, swiping will announce what the gesture does without executing it. Double tap to toggle." />
                
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDeduplicate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Deduplicate Speech"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:minHeight="64dp"
                    android:contentDescription="Toggle deduplicate speech. Prevents reading the exact same element twice in a row. Double tap to toggle." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Save Settings"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:contentDescription="Save settings. Double tap to save and apply your changes." />

    </LinearLayout>
</ScrollView>
